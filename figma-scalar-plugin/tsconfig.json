{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "typeRoots": [
      "../node_modules/@types",
      "../node_modules/@figma"
    ]
  },
  "include": [
    "code.ts",
    "src/**/*.ts",
    "renderer/**/*.ts",
    "exporter/**/*.ts",
    "hifi/**/*.ts",
    "../node_modules/@figma/plugin-typings/index.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
